# ===== RH grupo Lisbonb - Backend (.env) =====
# Copie este ficheiro para ".env" e preencha os valores reais.
# NUNCA faça commit do .env real (já está no .gitignore).

# --- Base de dados MongoDB (Atlas) ---
# No MongoDB Atlas: Database > Connect > Drivers > copie a connection string.
# Substitua <password> pela password do utilizador da BD.
MONGO_URL="mongodb+srv://utilizador:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
DB_NAME="rh_lisbonb"

# --- Segurança / JWT ---
# Gere uma chave aleatória forte, ex.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET="MUDAR-para-uma-chave-aleatoria-bem-longa"

# --- Admin principal (criado automaticamente no 1º arranque) ---
ADMIN_EMAIL="admin@grupolisbonb.pt"
# Password do admin em texto simples - o backend encripta-a no arranque.
# (Use só letras e números para evitar problemas com o '$' em .env/docker.)
ADMIN_PASSWORD="A-Sua-Password-Forte"
# Em alternativa, pode fornecer o hash bcrypt já pronto (gerado com
# generate_admin_hash.py). Se ADMIN_PASSWORD estiver definido, tem prioridade.
# ADMIN_PASSWORD_HASH="$2b$12$cole-aqui-o-hash-gerado"

# --- CORS: domínio(s) do frontend, separados por vírgula ---
# Em produção use o domínio real. Ex.: https://rh.grupolisbonb.pt
# Em desenvolvimento pode usar * (sem credenciais por cookie).
CORS_ORIGINS="http://localhost:3000"

# --- URL do frontend (usado nos links de email de recuperação) ---
FRONTEND_URL="http://localhost:3000"

# --- Emails (Resend) - para recuperação de palavra-passe ---
# Crie a chave em https://resend.com e verifique o seu domínio.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
SENDER_EMAIL="nao-responder@grupolisbonb.pt"

# --- Google Places API (Marketing → Avaliações por loja) ---
# Ative a "Places API" na Google Cloud Console e crie uma chave de API.
# A chave fica SÓ aqui no servidor (nunca no frontend nem no git).
# Cada loja é associada ao seu Place ID na página de Locais.
GOOGLE_PLACES_API_KEY=""
# Tempo de cache das avaliações em minutos (defeito 360 = 6h) para poupar quota.
GOOGLE_REVIEWS_CACHE_MINUTES="360"

# --- Porta do servidor (opcional, defeito 8000) ---
PORT="8000"

# ===== FINANCEIRO · FASE 4B — Ingestão automática de faturas (IMAP + IA) =====
# Endpoint de cron: POST /api/fin/cron/ingest?key=<CRON_KEY>
# Lê as caixas IMAP, manda cada PDF anexo à Claude (Haiku) para extrair os dados,
# descarta não-faturas e duplicados, associa à empresa pelo NIF do adquirente,
# aplica as regras do fornecedor, guarda o PDF e cria a fatura.

# --- Chave da API da Anthropic (Claude) ---
# Crie em https://console.anthropic.com. Usada para extrair os dados do PDF.
ANTHROPIC_API_KEY=""
# Modelo a usar (defeito: claude-haiku-4-5-20251001 — barato e rápido).
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"

# --- Chave que protege o endpoint de cron (sem isto, o endpoint devolve 403) ---
# Gere uma chave aleatória forte, ex.: python -c "import secrets; print(secrets.token_urlsafe(32))"
CRON_KEY=""

# --- Caixas de email IMAP a ler (JSON array, numa única linha) ---
# Cada objeto: host, port (opcional, defeito 993), user, pass (password de
# aplicação no caso do Gmail) e company_nif (NIF da empresa de fallback usada se
# a IA não conseguir associar a fatura pelo NIF do adquirente).
# Exemplo (substitua pelos valores reais):
# IMAP_MAILBOXES='[{"host":"imap.gmail.com","port":993,"user":"x@y.com","pass":"app-password","company_nif":"517542510"}]'
IMAP_MAILBOXES="[]"

# ===== FINANCEIRO · FASE 5B — Sincronização de vendas Vendus (POS) =====
# Sincroniza as vendas do Vendus para o módulo Vendas (fin_sales), por loja+dia.
# Manual:  POST /api/fin/vendus/sync (JWT) — botão "Sincronizar" no frontend.
# Cron:    POST /api/fin/cron/vendus?key=<CRON_KEY> — todas as contas, com CMV.
# Reutiliza a CRON_KEY definida acima.

# --- Contas Vendus (JSON array, numa única linha) ---
# Uma entrada por conta/empresa: key = chave da API do Vendus (Configurações >
# API); company_nif = NIF da empresa correspondente em fin_companies (é assim
# que o motor sabe a que empresa pertencem as vendas dessa conta).
# Exemplo (substitua pelos valores reais). NOTA: SEM aspas à volta do valor —
# o docker-compose lê o .env literalmente (mesmo padrão do IMAP_MAILBOXES real):
# VENDUS_ACCOUNTS=[{"key":"CHAVE_API","company_nif":"517542510"},{"key":"CHAVE_API","company_nif":"503109479"}]
VENDUS_ACCOUNTS=[]
