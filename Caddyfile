# ===== RH grupo Lisbonb - Caddy (HTTPS automático) =====
# O Caddy obtém e renova sozinho o certificado Let's Encrypt para o domínio,
# e encaminha o tráfego para o frontend (que por sua vez serve o site e o /api).
#
# Requisitos: o domínio tem de apontar para o IP do VPS (registo A) e as
# portas 80 e 443 têm de estar abertas.

rh.lisbonb.com {
    encode gzip
    reverse_proxy frontend:80
}

# ===== L'Açaí — API (app iOS/Android) =====
api.olacai.com {
    encode gzip
    reverse_proxy olacai-api:8001
}

# ===== L'Açaí — Painel web (admin/gestão) =====
admin.olacai.com {
    encode gzip
    reverse_proxy olacai-web:80
}

# ===== Menooo — plataforma de encomendas para restaurantes =====
menooo.com, www.menooo.com {
    encode gzip
    reverse_proxy 187.124.4.163:8080
}

painel.menooo.com {
    encode gzip
    reverse_proxy 187.124.4.163:8081
}

admin.menooo.com {
    encode gzip
    reverse_proxy 187.124.4.163:8082
}

api.menooo.com {
    encode gzip
    reverse_proxy 187.124.4.163:8083
}

# ===== L'açaí Estoque — gestão de stock das lojas =====
estoque.lisbonb.com {
    encode gzip
    reverse_proxy 187.124.4.163:8091
}
